@{
    ViewData["Title"] = "Order Success";
}

<div class="container py-5 text-center">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
    </div>
    
    <!-- Payment processing section -->
    @if (TempData["RazorpayOrderId"] != null)
    {
        <h1 class="display-4 mb-3">Initiating Payment...</h1>
        <p class="lead text-muted mb-4">Please complete your payment securely via Razorpay.</p>

        <form asp-controller="Checkout" asp-action="VerifyPayment" method="post" id="razorpayForm">
            <input type="hidden" name="order_number" value="@ViewBag.OrderNumber" />
            <input type="hidden" name="razorpay_payment_id" id="razorpay_payment_id" />
            <input type="hidden" name="razorpay_order_id" id="razorpay_order_id" />
            <input type="hidden" name="razorpay_signature" id="razorpay_signature" />
        </form>

        <button id="rzp-button1" class="btn btn-primary px-5 py-3 rounded-pill btn-lg mb-4 shadow">
            <i class="fa-solid fa-lock me-2"></i> Pay ₹@TempData["Amount"] Securely
        </button>

        @section Scripts {
            <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
            <script>
                var options = {
                    "key": "rzp_test_YOUR_KEY_HERE", 
                    "amount": "@((Convert.ToDecimal(TempData["Amount"]) * 100).ToString("0"))",
                    "currency": "INR",
                    "name": "Shree Om Hardware",
                    "description": "Payment for Order @ViewBag.OrderNumber",
                    "image": "https://example.com/your_logo",
                    "order_id": "@TempData["RazorpayOrderId"]", 
                    "handler": function (response){
                        document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                        document.getElementById('razorpay_order_id').value = response.razorpay_order_id;
                        document.getElementById('razorpay_signature').value = response.razorpay_signature;
                        document.getElementById('razorpayForm').submit();
                    },
                    "prefill": {
                        "name": "@User.Identity?.Name",
                        "email": "@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value"
                    },
                    "theme": {
                        "color": "#F97316"
                    }
                };
                var rzp1 = new Razorpay(options);
                rzp1.on('payment.failed', function (response){
                        window.location.href = '/Checkout/PaymentFailed?orderNumber=@ViewBag.OrderNumber';
                });
                
                document.getElementById('rzp-button1').onclick = function(e){
                    rzp1.open();
                    e.preventDefault();
                }

                // Auto-open
                window.onload = function() {
                    document.getElementById('rzp-button1').click();
                };
            </script>
        }
    }
    else
    {
        <h1 class="display-4 mb-3">Order Placed Successfully! (Offline)</h1>
        @if (ViewBag.OrderNumber != null)
        {
            <p class="lead text-muted mb-4">
                Thank you for shopping with Shree Om Hardware. Your order number is
                <strong>@ViewBag.OrderNumber</strong>
            </p>
        }
        
        <div class="alert alert-info d-inline-block text-start mb-5 shadow-sm border-0">
            <h5 class="alert-heading"><i class="bi bi-envelope-check me-2"></i>What's next?</h5>
            <p class="mb-0">You will receive an email confirmation shortly. We will notify you once your order has been shipped.</p>
        </div>
        
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 py-2 me-2">
                <i class="bi bi-house-door me-2"></i>Return to Home
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                <i class="bi bi-bag me-2"></i>Continue Shopping
            </a>
        </div>
    }
</div>
