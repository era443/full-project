@{
    ViewData["Title"] = "Payment Success";
}

<div class="container py-5 text-center" style="max-width: 600px;">
    <div class="mb-4">
        <i class="fa-solid fa-circle-check text-success" style="font-size: 5rem;"></i>
    </div>
    
    <h1 class="display-4 mb-3 text-success font-weight-bold">Payment Successful!</h1>
    
    @if (ViewBag.OrderNumber != null)
    {
        <p class="lead text-muted mb-4">
            Thank you for your payment. Your order <strong>@ViewBag.OrderNumber</strong> has been successfully processed and is now marked as Paid.
        </p>
    }
    
    <div class="card border-0 shadow-sm mb-5 text-start bg-light">
        <div class="card-body">
            <h5 class="card-title text-success"><i class="fa-solid fa-truck-fast me-2"></i> What's Next?</h5>
            <p class="card-text text-muted mb-0">We are preparing your order. You will receive an email confirmation with tracking details once it has been shipped.</p>
        </div>
    </div>
    
    <div>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill me-2">
            <i class="fa-solid fa-bag-shopping me-2"></i>Continue Shopping
        </a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
            <i class="fa-solid fa-house me-2"></i>Home
        </a>
    </div>
</div>
