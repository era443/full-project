@model shree_om.Models.ViewModels.ShoppingCartViewModel
@{
    ViewData["Title"] = "Checkout";
}

<!-- Include Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 font-sans relative">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Checkout</h1>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Left Column: Shipping & Payment -->
    <form id="checkoutForm" class="space-y-6 bg-white p-6 rounded-lg shadow-sm border border-gray-100 h-fit" onsubmit="handleCheckoutSubmit(event)">
      @Html.AntiForgeryToken()
      
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Shipping Information</h2>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
        <input type="text" name="FullName" id="FullName" value="@User.Identity?.Name" required class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <input type="email" name="Email" id="Email" value="@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value" readonly class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm bg-gray-50 text-gray-500 cursor-not-allowed" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
        <input type="text" name="PhoneNo" id="PhoneNo" required class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm" placeholder="+91 " />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <textarea name="Address" id="Address" required rows="3" class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm" placeholder="123 Street Name, Apartment, etc."></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
          <input type="text" name="City" id="City" required class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Postal Code</label>
          <input type="text" name="PostalCode" id="PostalCode" required class="w-full px-4 py-2 border rounded-md focus:ring-orange-500 focus:border-orange-500 outline-none text-sm" />
        </div>
      </div>
      
      <h2 class="text-xl font-semibold mt-8 mb-4 border-b pb-2">Payment Method</h2>
      
      <div class="space-y-3" id="paymentMethods">
         <label class="payment-option flex items-center gap-3 p-4 border rounded-lg cursor-pointer transition-all border-orange-500 bg-orange-50" data-val="Razorpay">
            <input type="radio" name="PaymentMethod" value="Razorpay" checked class="accent-orange-500 w-4 h-4" onchange="updatePaymentSelect(this)"/>
            <div class="flex-1">
              <div class="flex justify-between items-center">
                <span class="font-semibold text-slate-800 text-sm">Razorpay (Cards / UPI / NetBanking)</span>
                <!-- razorpay logo mock -->
                <svg width="60" height="16" viewBox="0 0 100 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="100" height="24" rx="4" fill="#02042B"/>
                  <path d="M28.3 7h-6v10h2v-4.3h3l2.8 4.3h2.3l-3.2-4.6c1.3-.4 2.2-1.7 2.2-3.1 0-1.8-1.3-2.3-3.1-2.3zm-4 4V8.5h3.9c.7 0 1.2.3 1.2 1.2 0 .9-.5 1.3-1.2 1.3h-3.9z" fill="#fff"/>
                </svg>
              </div>
              <span class="text-xs text-gray-500">Secure online payment via Razorpay.</span>
            </div>
         </label>

         <label class="payment-option flex items-center gap-3 p-4 border rounded-lg cursor-pointer transition-all border-gray-200" data-val="COD">
            <input type="radio" name="PaymentMethod" value="COD" class="accent-orange-500 w-4 h-4" onchange="updatePaymentSelect(this)"/>
            <div class="flex-1">
              <span class="font-semibold text-slate-800 text-sm">Cash on Delivery</span><br/>
              <span class="text-xs text-gray-500">Pay when you receive the items.</span>
            </div>
         </label>
      </div>

      <button type="submit" id="submitCheckoutBtn" class="w-full bg-orange-500 text-white font-semibold flex justify-center items-center py-3 rounded-md hover:bg-orange-600 transition-colors shadow-sm mt-6">
        <span>Pay ₹@Model.CartTotal.ToString("N0") Securely</span>
        <div id="btnSpinner" class="hidden ml-2 animate-spin w-4 h-4 border-2 border-white border-t-transparent rounded-full"></div>
      </button>
    </form>

    <!-- Right Column: Order Summary -->
    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 shadow-sm h-fit sticky top-6">
      <h2 class="text-lg font-semibold mb-4 text-slate-800">Order Summary</h2>
      
      <div class="space-y-4 mb-6 max-h-80 overflow-y-auto pr-2">
        @foreach (var item in Model.Items)
        {
          <div class="flex gap-4 items-center bg-white p-3 rounded-md border border-gray-100 shadow-sm">
            @if (!string.IsNullOrEmpty(item.ImageUrl))
            {
               <img src="@item.ImageUrl" alt="@item.ProductName" class="w-16 h-16 object-cover rounded bg-white border border-gray-50" />
            }
            else
            {
               <div class="w-16 h-16 bg-gray-100 rounded flex items-center justify-center text-gray-400"><i class="fa-solid fa-box-open"></i></div>
            }
            
            <div class="flex-1">
              <h4 class="text-sm font-medium text-gray-900 line-clamp-1">@item.ProductName</h4>
              <p class="text-xs text-gray-500 mt-1">Qty: @item.Quantity</p>
            </div>
            <div class="text-sm font-semibold text-orange-600">₹@item.Total.ToString("N0")</div>
          </div>
        }
      </div>

      <div class="border-t border-gray-200 pt-4 space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Subtotal (@Model.Items.Sum(i => i.Quantity) items)</span>
          <span class="font-medium text-slate-800">₹@Model.CartTotal.ToString("N0")</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Shipping</span>
          <span class="text-green-600 font-medium">Free</span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Handling Fee</span>
          <span class="font-medium text-slate-800">₹0</span>
        </div>
        <div class="flex justify-between text-xl font-bold mt-4 pt-4 border-t border-gray-200">
          <span class="text-slate-800">Total</span>
          <span class="text-orange-600">₹@Model.CartTotal.ToString("N0")</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Hidden Form to submit Razorpay success explicitly -->
<form id="razorpayVerifyForm" asp-action="VerifyPayment" method="post" style="display:none;">
    <input type="hidden" name="order_number" id="rzp_order_number" />
    <input type="hidden" name="razorpay_payment_id" id="razorpay_payment_id" />
    <input type="hidden" name="razorpay_order_id" id="razorpay_order_id" />
    <input type="hidden" name="razorpay_signature" id="razorpay_signature" />
</form>

<script>
    function updatePaymentSelect(radioEl) {
        const labels = document.querySelectorAll('.payment-option');
        labels.forEach(l => {
            l.classList.remove('border-orange-500', 'bg-orange-50');
            l.classList.add('border-gray-200');
        });
        const parent = radioEl.closest('.payment-option');
        parent.classList.remove('border-gray-200');
        parent.classList.add('border-orange-500', 'bg-orange-50');

        const submitBtnText = document.querySelector('#submitCheckoutBtn span');
        if (radioEl.value === 'Razorpay') {
            submitBtnText.innerHTML = `Pay ₹@Model.CartTotal.ToString("N0") Securely`;
        } else {
            submitBtnText.innerHTML = `Place Order via COD`;
        }
    }

    async function handleCheckoutSubmit(e) {
        e.preventDefault();
        
        const form = e.target;
        const formData = new FormData(form);
        const submitBtnAttr = document.getElementById('submitCheckoutBtn');
        const spinner = document.getElementById('btnSpinner');
        
        submitBtnAttr.disabled = true;
        submitBtnAttr.classList.add('opacity-75', 'cursor-not-allowed');
        spinner.classList.remove('hidden');

        try {
            const response = await fetch('/Checkout/PlaceOrder', {
                method: 'POST',
                body: formData
            });
            const data = await response.json();

            if (data.success) {
                if (data.isRazorpay) {
                    // Trigger Razorpay identically to React popup overlay
                    const options = {
                        "key": data.key,
                        "amount": (data.amount * 100).toString(),
                        "currency": "INR",
                        "name": "Shree Om Hardware",
                        "description": "Payment for Order " + data.orderNumber,
                        "image": "/images/logo.png",
                        "order_id": data.razorpayOrderId,
                        "handler": function (response){
                            // Inject values and submit secretly
                            document.getElementById('rzp_order_number').value = data.orderNumber;
                            document.getElementById('razorpay_payment_id').value = response.razorpay_payment_id;
                            document.getElementById('razorpay_order_id').value = response.razorpay_order_id;
                            document.getElementById('razorpay_signature').value = response.razorpay_signature;
                            document.getElementById('razorpayVerifyForm').submit();
                        },
                        "prefill": {
                            "name": data.customerName,
                            "email": data.customerEmail,
                            "contact": data.customerPhone
                        },
                        "theme": {
                            "color": "#F97316"
                        }
                    };
                    
                    const rzp = new window.Razorpay(options);
                    rzp.on('payment.failed', function (resp){
                        window.location.href = `/Checkout/PaymentFailed?orderNumber=${data.orderNumber}`;
                    });
                    rzp.open();
                    
                    // Re-enable button underneath popup
                    submitBtnAttr.disabled = false;
                    submitBtnAttr.classList.remove('opacity-75', 'cursor-not-allowed');
                    spinner.classList.add('hidden');
                } else {
                    // Navigate directly for COD
                    window.location.href = `/Checkout/PaymentSuccess?orderNumber=${data.orderNumber}`;
                }
            } else {
                alert(data.message || "Failed to process checkout.");
                submitBtnAttr.disabled = false;
                submitBtnAttr.classList.remove('opacity-75', 'cursor-not-allowed');
                spinner.classList.add('hidden');
            }
        } catch (error) {
            console.error(error);
            alert("Network error processing your checkout.");
            submitBtnAttr.disabled = false;
            submitBtnAttr.classList.remove('opacity-75', 'cursor-not-allowed');
            spinner.classList.add('hidden');
        }
    }
</script>
