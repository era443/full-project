    <div class="container">
        <h2 class="section-title">What Our Customers Say</h2>
        <div class="testimonials-grid">
            <div class="testimonial-card">
                <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                <p class="quote">"Excellent quality products! The door handles are sturdy and look premium. Very happy with my purchase."</p>
                <div class="author">
                    <div class="avatar">RK</div>
                    <div class="info">
                        <div class="name">Rajesh Kumar</div>
                        <div class="loc">Ahmedabad</div>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                <p class="quote">"Best hardware shop online. Fast delivery and great customer service. Highly recommended!"</p>
                <div class="author">
                    <div class="avatar">PS</div>
                    <div class="info">
                        <div class="name">Priya Sharma</div>
                        <div class="loc">Mumbai</div>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <div class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i></div>
                <p class="quote">"Premium quality at affordable prices. The locks are very secure. Will definitely order again."</p>
                <div class="author">
                    <div class="avatar">AP</div>
                    <div class="info">
                        <div class="name">Amit Patel</div>
                        <div class="loc">Rajkot</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
