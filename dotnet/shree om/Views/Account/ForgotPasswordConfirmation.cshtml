@{
    ViewData["Title"] = "Check Your Email – Shree Om Hardware";
    Layout = "_Layout";
    string email = ViewData["Email"]?.ToString() ?? "your email";
}

<div class="auth-page">
    <div class="auth-card confirm-card">
        <h2>Reset Your Password</h2>
        <p class="auth-sub" style="color:var(--orange);">Check your email for the reset link</p>

        <p class="info-text">
            We've sent a password reset link to<br />
            <span class="email-highlight">@email</span>
        </p>

        <a asp-controller="Account" asp-action="Login" class="btn-ghost" style="margin-bottom:16px;">Back to Login</a>

        <div class="auth-divider">
            <a asp-controller="Account" asp-action="Login" class="link-orange">Remember password? Back to Login</a>
        </div>
    </div>
</div>
