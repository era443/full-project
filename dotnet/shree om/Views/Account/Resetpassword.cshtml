@model shree_om.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password – Shree Om Hardware";
}

<style>
    /* ── Password Strength Bar ── */
    .pw-strength-bar { height: 4px; border-radius: 4px; background: var(--border); margin-top: 6px; overflow: hidden; }
    .pw-strength-fill { height: 100%; width: 0; border-radius: 4px; transition: width .3s, background .3s; }
    .pw-strength-label { font-size: 12px; margin-top: 4px; font-weight: 600; }
    .pw-match-msg { font-size: 12px; margin-top: 4px; }
    .pw-match-ok   { color: #16A34A; }
    .pw-match-fail { color: #DC2626; }
</style>

<section class="auth-section">
    <div class="auth-card" style="max-width:460px; width:100%;">

        <div class="auth-logo"><div class="logo-box">SO</div></div>
        <h2 style="text-align:center; margin-bottom:4px;">Set New Password</h2>
        <p class="auth-sub" style="text-align:center; margin-bottom:24px;">Create a strong password for your account</p>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
        {
            <div class="alert-danger" style="margin-bottom:16px;">
                <i class="fa-solid fa-circle-exclamation" style="margin-right:6px;"></i>
                @foreach (var state in ViewData.ModelState.Values)
                {
                    foreach (var error in state.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <form asp-action="ResetPassword" asp-controller="Account" method="post" id="resetForm" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <!-- New Password -->
            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <div class="password-wrap">
                    <input asp-for="NewPassword" type="password" id="newPassword"
                           placeholder="Min. 6 characters"
                           autocomplete="new-password"
                           oninput="checkStrength(this.value); checkMatch()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('newPassword', this)" tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <!-- Strength bar -->
                <div class="pw-strength-bar"><div class="pw-strength-fill" id="strengthFill"></div></div>
                <div class="pw-strength-label" id="strengthLabel" style="color:var(--text-grey);">Enter a password</div>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <div class="password-wrap">
                    <input asp-for="ConfirmPassword" type="password" id="confirmPassword"
                           placeholder="Re-enter new password"
                           autocomplete="new-password"
                           oninput="checkMatch()" />
                    <button type="button" class="toggle-pw" onclick="togglePw('confirmPassword', this)" tabindex="-1">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <div class="pw-match-msg" id="matchMsg"></div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Password Requirements -->
            <div style="background:var(--bg-light); border-radius:8px; padding:12px 14px; margin-bottom:20px; font-size:13px;">
                <div style="font-weight:600; margin-bottom:8px; color:var(--text-dark);">Password must contain:</div>
                <div id="req-len"  class="req-item">✗ At least 6 characters</div>
                <div id="req-num"  class="req-item">✗ At least one number</div>
                <div id="req-up"   class="req-item">✗ At least one uppercase letter</div>
                <div id="req-spec" class="req-item">✗ At least one special character</div>
            </div>

            <button type="submit" class="btn-orange w-full" id="resetBtn">
                Reset Password &nbsp;<i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <div class="auth-divider">
            <a asp-controller="Account" asp-action="Login" class="link-orange">← Back to Login</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .req-item { color: #DC2626; margin-bottom: 4px; transition: color .2s; }
        .req-item.ok { color: #16A34A; }
        .req-item.ok::first-letter { content: '✓'; }
    </style>
    <script>
        function togglePw(id, btn) {
            var inp = document.getElementById(id);
            inp.type = inp.type === 'password' ? 'text' : 'password';
            btn.querySelector('i').classList.toggle('fa-eye');
            btn.querySelector('i').classList.toggle('fa-eye-slash');
        }

        function setReq(id, ok) {
            var el = document.getElementById(id);
            el.classList.toggle('ok', ok);
            el.textContent = (ok ? '✓ ' : '✗ ') + el.textContent.slice(2);
        }

        function checkStrength(val) {
            var fill   = document.getElementById('strengthFill');
            var label  = document.getElementById('strengthLabel');

            var hasLen  = val.length >= 6;
            var hasNum  = /\d/.test(val);
            var hasUp   = /[A-Z]/.test(val);
            var hasSpec = /[^A-Za-z0-9]/.test(val);

            // Update req items
            setReq('req-len',  hasLen);
            setReq('req-num',  hasNum);
            setReq('req-up',   hasUp);
            setReq('req-spec', hasSpec);

            var score = [hasLen, hasNum, hasUp, hasSpec].filter(Boolean).length;

            var configs = [
                { pct: '0%',   color: '#E5E7EB', text: 'Enter a password',    textColor: 'var(--text-grey)' },
                { pct: '25%',  color: '#EF4444', text: 'Weak',                textColor: '#EF4444' },
                { pct: '50%',  color: '#F97316', text: 'Fair',                textColor: '#F97316' },
                { pct: '75%',  color: '#EAB308', text: 'Good',                textColor: '#EAB308' },
                { pct: '100%', color: '#16A34A', text: 'Strong ✓',            textColor: '#16A34A' },
            ];

            if (val.length === 0) score = 0;
            var cfg = configs[score];
            fill.style.width     = cfg.pct;
            fill.style.background = cfg.color;
            label.textContent    = cfg.text;
            label.style.color    = cfg.textColor;
        }

        function checkMatch() {
            var pw   = document.getElementById('newPassword').value;
            var conf = document.getElementById('confirmPassword').value;
            var msg  = document.getElementById('matchMsg');
            if (conf.length === 0) { msg.textContent = ''; return; }
            if (pw === conf) {
                msg.textContent = '✓ Passwords match';
                msg.className = 'pw-match-msg pw-match-ok';
            } else {
                msg.textContent = '✗ Passwords do not match';
                msg.className = 'pw-match-msg pw-match-fail';
            }
        }
    </script>
}