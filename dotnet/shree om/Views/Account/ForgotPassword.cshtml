@model shree_om.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password – Shree Om Hardware";
    Layout = "_Layout";
}

<div class="auth-page" style="background:white;">
    <div style="max-width: 640px; margin: 0 auto; padding: 60px 20px;">
        <h2 style="text-align:center; font-size:26px; font-weight:800; margin-bottom:10px;">Reset Your Password</h2>
        <p style="text-align:center; color:var(--text-grey); margin-bottom:32px;">
            Enter your email address and we'll send you a reset link
        </p>

        <form asp-action="ForgotPassword" asp-controller="Account" method="post" style="max-width:380px; margin:0 auto;">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email" style="text-transform:uppercase; font-size:12px; letter-spacing:.06em;">Email Address</label>
                <input asp-for="Email" type="email" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-orange w-full" style="margin-bottom:20px;">Send Reset Link</button>
        </form>

        <div style="text-align:center;">
            <a asp-controller="Account" asp-action="Login" class="link-orange">Remember password? Back to Login</a>
        </div>

        <hr style="margin:40px auto; max-width:380px; border:none; border-top:1px solid var(--border);" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
