@model IEnumerable<shree_om.Models.User>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h2 class="text-2xl font-bold text-slate-800">Users</h2>
        <p class="text-gray-500 text-sm mt-1">Manage customer and admin accounts</p>
    </div>
    <a asp-action="AddUser" class="bg-orange-500 text-white px-4 py-2 rounded-md font-medium hover:bg-orange-600 transition-colors shadow-sm flex items-center gap-2">
        <i class="fa-solid fa-user-plus"></i> Add User
    </a>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-100 text-xs uppercase tracking-wider text-gray-500 font-semibold">
                    <th class="py-3 px-6 w-16 text-center">Avatar</th>
                    <th class="py-3 px-6">Name</th>
                    <th class="py-3 px-6">Email</th>
                    <th class="py-3 px-6">Phone</th>
                    <th class="py-3 px-6 text-center">Role</th>
                    <th class="py-3 px-6 text-center">Verified</th>
                    <th class="py-3 px-6 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="py-10 text-center text-gray-500">No users found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var user in Model)
                    {
                        var isCurrentAdmin = (user.Email == User.Identity?.Name) || (!string.IsNullOrEmpty(user.Email) && user.Email.Contains("admin"));
                        <tr class="border-b border-gray-50 hover:bg-gray-50 transition-colors">
                            <td class="py-3 px-6">
                                <div class="w-10 h-10 bg-orange-100 text-orange-600 rounded-full mx-auto flex items-center justify-center font-bold uppercase">
                                    @(user.FullName?.FirstOrDefault() ?? 'U')
                                </div>
                            </td>
                            <td class="py-3 px-6 font-medium text-slate-800">@user.FullName</td>
                            <td class="py-3 px-6 text-gray-600">@user.Email</td>
                            <td class="py-3 px-6 text-gray-600">@(string.IsNullOrEmpty(user.PhoneNumber) ? "N/A" : user.PhoneNumber)</td>
                            <td class="py-3 px-6 text-center">
                                <span class="px-2 py-1 text-[10px] font-bold uppercase tracking-wider rounded-full @(user.Role == "Admin" ? "bg-purple-100 text-purple-700" : "bg-gray-100 text-gray-700")">
                                    @user.Role
                                </span>
                            </td>
                            <td class="py-3 px-6 text-center">
                                @if (user.IsEmailVerified)
                                {
                                    <i class="fa-solid fa-circle-check text-green-500"></i>
                                }
                                else
                                {
                                    <i class="fa-regular fa-circle-xmark text-red-400"></i>
                                }
                            </td>
                            <td class="py-3 px-6 text-right space-x-2">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="text-blue-500 hover:text-blue-700 hover:bg-blue-50 p-1.5 rounded transition-colors inline-block" title="Edit">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                @if (!isCurrentAdmin)
                                {
                                    <form asp-action="DeleteUser" method="post" class="inline-block" onsubmit="return confirm('Are you sure you want to completely delete this user?');">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="text-red-500 hover:text-red-700 hover:bg-red-50 p-1.5 rounded transition-colors" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button disabled class="text-gray-300 p-1.5 rounded cursor-not-allowed" title="Cannot delete self/admin">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
