@model shree_om.Models.User
@{
    ViewData["Title"] = "Add User";
    Layout = "_AdminLayout";
}

<div class="mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <a asp-action="Users" class="text-gray-400 hover:text-orange-500 transition-colors">
            <i class="fa-solid fa-arrow-left text-xl"></i>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Add User</h2>
            <p class="text-gray-500 text-sm mt-1">Register a new account manually</p>
        </div>
    </div>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden p-6 sm:p-8 max-w-3xl">
    <form asp-action="AddUser" method="post" class="space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Full Name <span class="text-red-500">*</span></label>
                <input type="text" asp-for="FullName" required class="w-full px-4 py-2.5 border border-gray-200 rounded-md focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none text-sm" />
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Email Address <span class="text-red-500">*</span></label>
                <input type="email" asp-for="Email" required class="w-full px-4 py-2.5 border border-gray-200 rounded-md focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none text-sm" />
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                <input type="tel" asp-for="PhoneNumber" class="w-full px-4 py-2.5 border border-gray-200 rounded-md focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none text-sm" />
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Password <span class="text-red-500">*</span></label>
                <!-- Because the signature takes string password in AdminController we map it manually or just name it password -->
                <input type="password" name="password" required class="w-full px-4 py-2.5 border border-gray-200 rounded-md focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none text-sm" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Role <span class="text-red-500">*</span></label>
                <select asp-for="Role" required class="w-full px-4 py-2.5 border border-gray-200 rounded-md focus:border-orange-500 focus:ring-1 focus:ring-orange-500 outline-none text-sm">
                    <option value="Customer">Customer</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>
            
            <div class="flex items-center mt-8">
                <label class="flex items-center gap-3 cursor-pointer">
                    <input type="checkbox" asp-for="IsEmailVerified" checked class="w-5 h-5 accent-orange-500 rounded cursor-pointer" />
                    <span class="text-sm font-medium text-gray-800">Email is Verified</span>
                </label>
            </div>
        </div>

        <div class="pt-6 border-t border-gray-100 flex gap-4 mt-8">
            <button type="submit" class="bg-orange-500 text-white font-semibold py-2.5 px-8 rounded-md hover:bg-orange-600 transition-colors shadow-sm">
                Create User
            </button>
            <a asp-action="Users" class="bg-white border border-gray-200 text-gray-700 font-semibold py-2.5 px-8 rounded-md hover:bg-gray-50 transition-colors shadow-sm">
                Cancel
            </a>
        </div>
    </form>
</div>
