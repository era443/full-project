@model shree_om.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
    var categories = ViewBag.Categories as IEnumerable<shree_om.Models.Category>;
}

<div class="min-h-screen bg-gray-50 -m-8 p-8 font-sans">
  <div class="max-w-4xl mx-auto px-6 py-8">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Edit Product</h1>
    </div>

    <!-- Form -->
    <form asp-action="EditProduct" method="post" enctype="multipart/form-data" class="bg-white rounded-lg border border-gray-200 p-6">
      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="CreatedAt" />
      <input type="hidden" asp-for="Rating" />
      <input type="hidden" asp-for="ReviewCount" />
        
      <div class="grid grid-cols-2 gap-6">
        
        <!-- Product Name -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Product Name</label>
          <input type="text" asp-for="Name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- SKU -->
        <div class="col-span-2 md:col-span-1">
            <label class="block text-sm font-medium text-gray-700 mb-2">SKU</label>
            <input type="text" name="sku" value="@Model.Id.ToString()" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- Category -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Category</label>
          <select asp-for="CategoryId" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white appearance-none">
            <option value="">Select Category</option>
            @if(categories != null)
            {
                foreach(var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
          </select>
        </div>

        <!-- Stock -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Stock</label>
          <input type="number" asp-for="Stock" min="0" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- Price -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Price (₹)</label>
          <input type="number" asp-for="Price" step="0.01" min="0" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- Product Image (File input) -->
        <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-2">Product Image</label>
            <div class="flex flex-col gap-2">
                <input type="file" name="imageFile" accept="image/*" class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
                <input type="hidden" asp-for="ImageUrl" />
                <div class="text-xs text-gray-500">Leave empty to keep existing physical file.</div>
            </div>
        </div>

        <!-- Short Description -->
        <div class="col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-2">Short Description</label>
            <input type="text" name="shortDescription" value="@(Model.Description?.Length > 50 ? Model.Description.Substring(0, 50) + "..." : Model.Description)" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- Full Description -->
        <div class="col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-2">Full Description</label>
          <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent resize-none text-gray-900 bg-white"></textarea>
        </div>

        <!-- Material (Using Input in Edit) -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Material</label>
          <input type="text" asp-for="Material" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>

        <!-- Finish (Using Input in Edit) -->
        <div class="col-span-2 md:col-span-1">
          <label class="block text-sm font-medium text-gray-700 mb-2">Finish</label>
          <input type="text" asp-for="Finish" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent text-gray-900 bg-white" />
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex justify-end gap-3 mt-6 pt-6 border-t border-gray-200">
        <a asp-action="Products" class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 font-medium transition-colors bg-white">
          Cancel
        </a>
        <button type="submit" class="px-6 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-lg font-medium transition-colors">
          Update Product
        </button>
      </div>
    </form>
  </div>
</div>
